# Starts PostgreSQL (Podman), FastAPI, and both Streamlit portals.
# Usage (from project root in PowerShell): .\start.ps

$ErrorActionPreference = "Stop"

$ProjectRoot = $PSScriptRoot
Set-Location $ProjectRoot

$RunDir = Join-Path $ProjectRoot ".run"
$LogDir = Join-Path $RunDir "logs"
$StateFile = Join-Path $RunDir "services.json"

New-Item -ItemType Directory -Force -Path $LogDir | Out-Null

function Write-Step([string]$Message) {
    Write-Host "==> $Message" -ForegroundColor Cyan
}

function Get-ComposeCommand {
    if (Get-Command podman -ErrorAction SilentlyContinue) {
        return @{ Executable = "podman"; Arguments = @("compose") }
    }
    if (Get-Command podman-compose -ErrorAction SilentlyContinue) {
        return @{ Executable = "podman-compose"; Arguments = @() }
    }
    throw "Podman not found. Install Podman and ensure it is on PATH."
}

function Invoke-Compose {
    param([string[]]$ComposeArgs)

    $compose = Get-ComposeCommand
    $args = @($compose.Arguments + $ComposeArgs) | Where-Object { $_ }
    & $compose.Executable @args
    if ($LASTEXITCODE -ne 0) {
        throw "Compose command failed: $($compose.Executable) $($args -join ' ')"
    }
}

function Get-PythonExecutable {
    $venvPython = Join-Path $ProjectRoot ".venv\Scripts\python.exe"
    if (Test-Path $venvPython) {
        return $venvPython
    }

    $systemPython = Get-Command python -ErrorAction SilentlyContinue
    if ($systemPython) {
        Write-Host "Warning: .venv not found. Using system Python." -ForegroundColor Yellow
        return $systemPython.Source
    }

    throw "Python not found. Create a virtual environment first:`n  python -m venv .venv`n  .\.venv\Scripts\Activate.ps1`n  pip install -r requirements.txt"
}

function Test-ServiceRunning([int]$ProcessId) {
    return (Get-Process -Id $ProcessId -ErrorAction SilentlyContinue) -ne $null
}

function Start-AppProcess {
    param(
        [string]$Name,
        [string[]]$Arguments,
        [string]$LogFile
    )

    $python = Get-PythonExecutable
    $stdout = Join-Path $LogDir $LogFile
    $stderr = "$stdout.err"

    $process = Start-Process `
        -FilePath $python `
        -ArgumentList $Arguments `
        -WorkingDirectory $ProjectRoot `
        -WindowStyle Hidden `
        -PassThru `
        -RedirectStandardOutput $stdout `
        -RedirectStandardError $stderr

    return @{
        name = $Name
        pid  = $process.Id
        log  = $stdout
    }
}

function Wait-ForDatabase {
    param([int]$TimeoutSeconds = 60)

    Write-Step "Waiting for PostgreSQL to become healthy..."
    $deadline = (Get-Date).AddSeconds($TimeoutSeconds)

    while ((Get-Date) -lt $deadline) {
        $status = podman inspect ecommerce_fraud --format "{{.State.Health.Status}}" 2>$null
        if ($status -eq "healthy") {
            Write-Host "PostgreSQL is healthy." -ForegroundColor Green
            return
        }

        $running = podman inspect ecommerce_fraud --format "{{.State.Running}}" 2>$null
        if ($running -eq "true" -and -not $status) {
            Write-Host "PostgreSQL is running (no healthcheck reported)." -ForegroundColor Green
            return
        }

        Start-Sleep -Seconds 2
    }

    throw "PostgreSQL did not become ready within $TimeoutSeconds seconds. Check: podman logs ecommerce_fraud"
}

if (Test-Path $StateFile) {
    $existing = Get-Content $StateFile -Raw | ConvertFrom-Json
    $stillRunning = @($existing | Where-Object { Test-ServiceRunning $_.pid })
    if ($stillRunning.Count -gt 0) {
        Write-Host "Services appear to be running already. Run .\stop.ps first." -ForegroundColor Yellow
        foreach ($svc in $stillRunning) {
            Write-Host "  - $($svc.name) (PID $($svc.pid))"
        }
        exit 1
    }
}

if (-not (Test-Path (Join-Path $ProjectRoot ".env"))) {
    Write-Host "Warning: .env not found. Copy .env.example to .env and configure credentials." -ForegroundColor Yellow
}

Write-Step "Starting PostgreSQL container..."
Invoke-Compose -ComposeArgs @("-f", "podman-compose.yaml", "up", "-d")
Wait-ForDatabase

Write-Step "Starting application services..."
$services = @(
    (Start-AppProcess -Name "api" -Arguments @(
        "-m", "uvicorn", "api.main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"
    ) -LogFile "api.log")
    (Start-AppProcess -Name "customer" -Arguments @(
        "-m", "streamlit", "run", "customer_app.py", "--server.port", "8501", "--server.headless", "true"
    ) -LogFile "customer.log")
    (Start-AppProcess -Name "analyst" -Arguments @(
        "-m", "streamlit", "run", "analyst_app.py", "--server.port", "8502", "--server.headless", "true"
    ) -LogFile "analyst.log")
)

Start-Sleep -Seconds 3

$failed = @($services | Where-Object { -not (Test-ServiceRunning $_.pid) })
if ($failed.Count -gt 0) {
    foreach ($svc in $failed) {
        Write-Host "Failed to start $($svc.name). See log: $($svc.log)" -ForegroundColor Red
    }
    throw "One or more services failed to start."
}

$services | ConvertTo-Json -Depth 3 | Set-Content -Path $StateFile -Encoding UTF8

Write-Host ""
Write-Host "Metro Cart platform is running." -ForegroundColor Green
Write-Host ""
Write-Host "  API docs:         http://127.0.0.1:8000/docs"
Write-Host "  Customer portal:  http://localhost:8501"
Write-Host "  Analyst portal:   http://localhost:8502"
Write-Host ""
Write-Host "Logs: $LogDir"
Write-Host "Stop everything with: .\stop.ps"
